generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  COACH
  CLIENT
}

model Role {
  id    Int      @id @default(autoincrement())
  name  RoleName @unique
  users User[]
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  roleId    Int
  role      Role      @relation(fields: [roleId], references: [id])

  coach     Coach?
  admin     Admin?
  bookings  Booking[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Coach {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  user      User      @relation(fields: [userId], references: [id])
  sessions  Session[]
}

model Admin {
  id     Int   @id @default(autoincrement())
  userId Int   @unique
  user   User  @relation(fields: [userId], references: [id])
}

model Session {
  id               Int       @id @default(autoincrement())
  title            String
  description      String?
  date             DateTime
  duration         Int?
  maxParticipants  Int

  coachId          Int
  coach            Coach     @relation(fields: [coachId], references: [id])

  bookings         Booking[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([date])
}

model Booking {
  id         Int      @id @default(autoincrement())
  userId     Int
  sessionId  Int

  user       User     @relation(fields: [userId], references: [id])
  session    Session  @relation(fields: [sessionId], references: [id])

  createdAt  DateTime @default(now())

  @@unique([userId, sessionId])
  @@index([userId])
}
